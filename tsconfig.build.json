{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "lib": ["ESNext", "DOM"],
        "allowImportingTsExtensions": false,

        "module": "NodeNext", // or "ESNext" / "ES2022"
        "moduleResolution": "NodeNext" // must match module setting
    },
    "include": ["src/**/*.ts"],
    "exclude": ["tests/**", "node_modules/**", "dist/**"]
}
