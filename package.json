{
    "name": "kiriminaja",
    "version": "0.1.8",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "license": "MIT",
    "homepage": "https://developer.kiriminaja.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/kiriminaja/node.git"
    },
    "author": "Kiriminaja Team <team@kiriminaja.com>",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./adapters/h3": {
            "import": {
                "types": "./dist/adapters/h3.d.mts",
                "default": "./dist/adapters/h3.mjs"
            },
            "require": {
                "types": "./dist/adapters/h3.d.cts",
                "default": "./dist/adapters/h3.cjs"
            }
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.0",
        "changelogen": "^0.6.2",
        "tsdown": "^0.21.7",
        "typescript": "^6.0.0"
    },
    "peerDependencies": {
        "typescript": "^6"
    },
    "private": false,
    "scripts": {
        "release": "bun test && bun run build && changelogen --release && git push --follow-tags && npm publish --access=public",
        "build": "bun run clean && tsdown",
        "dev": "cd playground && bun dev",
        "clean": "rm -rf dist",
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    }
}
