{
  "name": "kiriminaja",
  "version": "0.1.6",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiriminaja/node.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./adapters/h3": {
      "types": "./dist/adapters/h3.d.ts",
      "import": "./dist/adapters/h3.mjs",
      "require": "./dist/adapters/h3.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "changelogen": "^0.6.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "private": false,
  "scripts": {
    "release": "bun test && bun run build && changelogen --release && git push --follow-tags && npm publish --access=public",
    "build": "bun run clean && tsup",
    "dev": "cd playground && bun dev",
    "clean": "rm -rf dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  }
}